# Sona AI OS — Environment Configuration
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Application ---
APP_NAME=sona-ai-os
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Database ---
# SQLite (default for development):
DATABASE_URL=sqlite:///data/sona.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://sona:sona@localhost:5432/sona_db

# --- Redis (optional — falls back to in-memory cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Vector Database (optional — falls back to in-memory vectors) ---
QDRANT_URL=http://localhost:6333

# --- AI Providers ---
# Ollama (local, free — just run `ollama serve`):
OLLAMA_URL=http://localhost:11434

# Gemini (free tier — get key at https://aistudio.google.com/apikey):
# GEMINI_API_KEY=

# --- Embeddings ---
# Ollama embedding model (pull via `ollama pull nomic-embed-text`):
EMBED_MODEL=nomic-embed-text

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
