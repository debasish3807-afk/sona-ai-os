# Sona AI OS — Environment Configuration
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Application ---
APP_NAME=sona-ai-os
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sona_ai_os
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- LLM Pool ---
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=claude-3-sonnet
MAX_TOKENS=4096
TEMPERATURE=0.7

# --- Vector Database ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=sona_memory

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- External Services ---
# GITHUB_TOKEN=
# SEARCH_API_KEY=
